{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://six-sigma-study.local/schemas/book-package.schema.json",
  "title": "Study App Book Package",
  "type": "object",
  "required": ["manual", "bookId", "version", "pageCount", "title", "source", "licenseNotice", "chapters", "dictionary"],
  "additionalProperties": true,
  "properties": {
    "manual": { "type": "string", "minLength": 1 },
    "bookId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{1,63}$" },
    "version": { "type": "string", "minLength": 1 },
    "pageCount": { "type": "integer", "minimum": 1 },
    "title": { "$ref": "#/$defs/localizedText" },
    "subtitle": { "$ref": "#/$defs/localizedText" },
    "domainLabel": { "type": "string" },
    "source": { "type": "string", "minLength": 3 },
    "licenseNotice": { "$ref": "#/$defs/localizedText" },
    "chapters": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/chapter" }
    },
    "dictionary": {
      "type": "array",
      "items": { "$ref": "#/$defs/termEntry" }
    }
  },
  "$defs": {
    "localizedText": {
      "type": "object",
      "required": ["en", "zh"],
      "additionalProperties": false,
      "properties": {
        "en": { "type": "string", "minLength": 1 },
        "zh": { "type": "string", "minLength": 1 }
      }
    },
    "chapter": {
      "type": "object",
      "required": ["id", "chapter", "pageStart", "pageEnd", "title", "sections"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "chapter": { "type": "integer", "minimum": 1 },
        "pageStart": { "type": "integer", "minimum": 1 },
        "pageEnd": { "type": "integer", "minimum": 1 },
        "title": { "$ref": "#/$defs/localizedText" },
        "sections": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/section" }
        },
        "assets": {
          "type": "array",
          "items": { "$ref": "#/$defs/asset" }
        }
      }
    },
    "section": {
      "type": "object",
      "required": ["id", "page", "level", "title", "content"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "page": { "type": "integer", "minimum": 1 },
        "level": { "type": "integer", "minimum": 1, "maximum": 3 },
        "title": { "$ref": "#/$defs/localizedText" },
        "content": {
          "type": "object",
          "required": ["en", "zh"],
          "additionalProperties": false,
          "properties": {
            "en": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/contentBlock" }
            },
            "zh": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/contentBlock" }
            }
          }
        }
      }
    },
    "contentBlock": {
      "type": "object",
      "required": ["id", "kind", "page"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["paragraph", "listItem", "table", "termNote", "heading", "image"] },
        "page": { "type": "integer", "minimum": 1 },
        "text": { "type": "string" },
        "rows": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "assetId": { "type": "string" },
        "src": { "type": "string" },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "alt": { "type": "string" }
      }
    },
    "asset": {
      "type": "object",
      "required": ["id", "type", "path", "page"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "type": { "enum": ["figure", "table-image", "formula-image"] },
        "path": { "type": "string" },
        "page": { "type": "integer", "minimum": 1 },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "caption": { "$ref": "#/$defs/localizedText" }
      }
    },
    "termEntry": {
      "type": "object",
      "required": ["term", "translation", "explanation", "lookupKeys"],
      "additionalProperties": true,
      "properties": {
        "term": { "type": "string", "minLength": 1 },
        "translation": { "type": "string", "minLength": 1 },
        "partOfSpeech": { "type": "string" },
        "phonetic": { "type": "string" },
        "explanation": { "type": "string", "minLength": 1 },
        "lookupKeys": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "isSixSigmaTerm": { "type": "boolean" },
        "source": { "type": "string" }
      }
    }
  }
}
