{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://six-sigma-study.local/schemas/agent-import-request.schema.json",
  "title": "Agent Textbook Import Request",
  "type": "object",
  "required": ["schemaVersion", "book", "sources", "conversionPlan", "reviewGates"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "type": "string", "pattern": "^1\\.0\\.0$" },
    "book": {
      "type": "object",
      "required": ["bookId", "title", "languagePair", "source", "licenseNotice", "intendedUse"],
      "additionalProperties": false,
      "properties": {
        "bookId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{1,63}$" },
        "title": { "$ref": "#/$defs/localizedText" },
        "subtitle": { "$ref": "#/$defs/localizedText" },
        "languagePair": {
          "type": "array",
          "items": { "enum": ["en", "zh"] },
          "contains": { "const": "en" },
          "minItems": 2,
          "uniqueItems": true
        },
        "domainLabel": { "type": "string" },
        "source": { "type": "string", "minLength": 3 },
        "sourceUrl": { "type": "string" },
        "accessedAt": { "type": "string" },
        "rightsStatus": {
          "enum": ["confirmed-public", "original-author-owned", "user-provided-approved", "blocked-unknown"]
        },
        "licenseNotice": { "$ref": "#/$defs/localizedText" },
        "intendedUse": { "enum": ["non-commercial-study", "internal-review-only"] }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type", "path", "rightsStatus"],
        "additionalProperties": false,
        "properties": {
          "type": { "enum": ["pdf", "docx", "bilingual-doc", "image-folder", "structured-json", "dictionary"] },
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string" },
          "language": { "enum": ["en", "zh", "mixed", "not-applicable"] },
          "rightsStatus": {
            "enum": ["confirmed-public", "original-author-owned", "user-provided-approved", "blocked-unknown"]
          },
          "notes": { "type": "string" }
        }
      }
    },
    "conversionPlan": {
      "type": "object",
      "required": ["outputContentPath", "runtimeContentPath", "alignmentLevel", "assetPolicy", "glossaryPolicy"],
      "additionalProperties": false,
      "properties": {
        "outputContentPath": { "type": "string", "pattern": "^content/books/[a-z0-9][a-z0-9-]*/manual\\.json$" },
        "runtimeContentPath": { "type": "string", "pattern": "^content/books/[a-z0-9][a-z0-9-]*/manual\\.json$" },
        "alignmentLevel": { "enum": ["chapter", "section", "block", "sentence"] },
        "assetPolicy": { "enum": ["preserve-original-images", "structured-tables-first", "no-images"] },
        "glossaryPolicy": { "enum": ["curated-only", "curated-plus-local-dictionary", "none"] },
        "allowCommercialUse": { "type": "boolean", "const": false }
      }
    },
    "reviewGates": {
      "type": "object",
      "required": ["copyright", "toc", "imageQuality", "terminology", "bilingualAlignment"],
      "additionalProperties": false,
      "properties": {
        "copyright": { "$ref": "#/$defs/reviewGate" },
        "toc": { "$ref": "#/$defs/reviewGate" },
        "imageQuality": { "$ref": "#/$defs/reviewGate" },
        "terminology": { "$ref": "#/$defs/reviewGate" },
        "bilingualAlignment": { "$ref": "#/$defs/reviewGate" }
      }
    }
  },
  "$defs": {
    "localizedText": {
      "type": "object",
      "required": ["en", "zh"],
      "additionalProperties": false,
      "properties": {
        "en": { "type": "string", "minLength": 1 },
        "zh": { "type": "string", "minLength": 1 }
      }
    },
    "reviewGate": {
      "type": "object",
      "required": ["required", "status"],
      "additionalProperties": false,
      "properties": {
        "required": { "type": "boolean" },
        "status": { "enum": ["pending", "passed", "blocked"] },
        "notes": { "type": "string" },
        "reviewer": { "type": "string" },
        "reviewedAt": { "type": "string" }
      }
    }
  }
}
