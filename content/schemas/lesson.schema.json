{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://six-sigma-study.local/schemas/lesson.schema.json",
  "title": "Six Sigma Study Lesson",
  "type": "object",
  "required": ["id", "chapter", "title"],
  "properties": {
    "id": { "type": "string" },
    "chapter": { "type": "integer", "minimum": 1 },
    "pageStart": { "type": "integer", "minimum": 1 },
    "pageEnd": { "type": "integer", "minimum": 1 },
    "title": {
      "type": "object",
      "required": ["en", "zh"],
      "properties": {
        "en": { "type": "string" },
        "zh": { "type": "string" }
      }
    },
    "paragraphs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "page", "en", "zh"],
        "properties": {
          "id": { "type": "string" },
          "page": { "type": "integer", "minimum": 1 },
          "en": { "type": "string" },
          "zh": { "type": "string" },
          "assetIds": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "page", "level", "title", "content"],
        "properties": {
          "id": { "type": "string" },
          "page": { "type": "integer", "minimum": 1 },
          "level": { "type": "integer", "minimum": 1, "maximum": 3 },
          "title": {
            "type": "object",
            "required": ["en", "zh"],
            "properties": {
              "en": { "type": "string" },
              "zh": { "type": "string" }
            }
          },
          "content": {
            "type": "object",
            "required": ["en", "zh"],
            "properties": {
              "en": {
                "type": "array",
                "items": { "$ref": "#/$defs/contentBlock" }
              },
              "zh": {
                "type": "array",
                "items": { "$ref": "#/$defs/contentBlock" }
              }
            }
          }
        }
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "path", "page"],
        "properties": {
          "id": { "type": "string" },
          "type": { "enum": ["figure", "table-image", "formula-image"] },
          "path": { "type": "string" },
          "page": { "type": "integer" },
          "width": { "type": "integer", "minimum": 1 },
          "height": { "type": "integer", "minimum": 1 },
          "caption": {
            "type": "object",
            "properties": {
              "en": { "type": "string" },
              "zh": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "contentBlock": {
      "type": "object",
      "required": ["id", "kind"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "enum": ["paragraph", "listItem", "table", "termNote", "heading", "image"] },
        "text": { "type": "string" },
        "assetId": { "type": "string" },
        "src": { "type": "string" },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "alt": { "type": "string" },
        "rows": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
